<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">
    <item>
        <selector>
            <item android:state_pressed="true">
                <shape>
                    <gradient
                        android:angle="0"
                        android:startColor="#0F55C8"
                        android:endColor="#073F9F" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="#335C9DFF" />
                </shape>
            </item>
            <item android:state_focused="true">
                <shape>
                    <gradient
                        android:angle="0"
                        android:startColor="#2E7CFB"
                        android:endColor="#0B54D3" />
                    <corners android:radius="14dp" />
                    <stroke android:width="2dp" android:color="#FFFFFF" />
                </shape>
            </item>
            <item>
                <shape>
                    <gradient
                        android:angle="0"
                        android:startColor="#3388FF"
                        android:endColor="#0B5BE7" />
                    <corners android:radius="14dp" />
                    <stroke android:width="1dp" android:color="#66FFFFFF" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>
