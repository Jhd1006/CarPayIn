sequenceDiagram
    participant User as User
    participant App as AAOS App
    participant Backend as Car Pay-in Backend
    participant Redis as carpayin-redis
    participant DB as Car Pay-in DB
    participant PMS as Parking PMS
    participant PmsRedis as pms-redis
    participant PMSDB as PMS DB
    participant PG as Mock PG
    participant PGDB as Mock PG DB
    participant Card as Mock Card
    participant CardDB as Mock Card DB
    participant MQTT as MQTT Broker
    participant LPR as LPR Camera

    App->>App: Detect ignition ON and parked=true
    App->>Backend: GET /fee/{session_id}

    Backend->>Redis: Read parking_fee_quote:{session_id}
    alt Fee quote is missing
        Backend->>DB: Read parking_sessions
        Backend->>PMS: Request current parking fee
        PMS-->>Backend: Return amount and duration
        Backend->>Redis: Save parking_fee_quote:{session_id}
    end

    Backend-->>App: Return fee information
    User->>App: Approve payment

    App->>Backend: POST /payment with session_id and amount
    Backend->>Redis: Validate parking_fee_quote:{session_id}
    Backend->>DB: Read parking_sessions
    Backend->>DB: Read vehicle_billing_keys
    Backend->>DB: INSERT transactions status=pending

    Backend->>PG: Request billing payment
    PG->>PGDB: Check idempotency_key
    PG->>Card: Request card approval by card_token
    Card->>CardDB: INSERT tx
    Card-->>PG: Return approval_no and card_tx_id
    PG->>PGDB: INSERT or UPDATE transactions
    PG-->>Backend: Return pg_tx_id and approval_no

    Backend->>DB: UPDATE transactions status=success
    Backend->>DB: INSERT payment_notification_outbox status=pending
    Backend->>DB: UPDATE parking_sessions status=completed
    Backend->>PMS: POST /payment/complete
    PMS->>PMSDB: UPDATE parking_sessions status=paid
    PMS->>PmsRedis: UPDATE parking_session:{lot_id}:{plate} status=paid
    PMS-->>Backend: Return success
    Backend-->>App: Return payment complete
    App->>App: parked=false
    Backend->>MQTT: publish payment.completed/{car_id} (QoS 1)
    MQTT-->>App: Payment completed notification

    Note over LPR,PMSDB: Car drives to exit gate
    LPR->>PMS: Detect plate at exit gate
    PMS->>PmsRedis: Read parking_session:{lot_id}:{plate}
    alt status=paid (Redis hit)
        PMS->>MQTT: Open exit barrier command
        PMS->>PmsRedis: Delete parking_session key
        PMS->>PMSDB: UPDATE parking_sessions status=exited
    else Redis miss (restart/TTL expired)
        PMS->>PMSDB: Read paid session by lot_id and plate
        alt paid session found
            PMS->>MQTT: Open exit barrier command
            PMS->>PMSDB: UPDATE parking_sessions status=exited
        else no paid session
            Note over PMS: Barrier stays closed (not paid)
        end
    else status=active (not paid)
        Note over PMS: Barrier stays closed (not paid)
    end
