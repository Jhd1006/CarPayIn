sequenceDiagram
    participant User as User
    participant App as AAOS App
    participant Backend as Car Pay-in Backend
    participant Redis as Redis
    participant DB as Car Pay-in DB
    participant PMS as Parking PMS
    participant PG as Mock PG
    participant PGDB as Mock PG DB
    participant Card as Mock Card
    participant CardDB as Mock Card DB
    participant SQS as Amazon SQS
    participant Lambda as Payment Notification Lambda
    participant IoT as AWS IoT Core

    App->>App: Detect ignition ON and parked=true
    App->>Backend: GET /fee/{session_id}

    Backend->>Redis: Read parking_fee_quote:{session_id}
    alt Fee quote is missing
        Backend->>DB: Read parking_sessions
        Backend->>PMS: Request current parking fee
        PMS-->>Backend: Return amount and duration
        Backend->>Redis: Save parking_fee_quote:{session_id}
    end

    Backend-->>App: Return fee information
    User->>App: Approve payment

    App->>Backend: POST /payment with session_id and amount
    Backend->>Redis: Validate parking_fee_quote:{session_id}
    Backend->>DB: Read parking_sessions
    Backend->>DB: Read vehicle_billing_keys
    Backend->>DB: INSERT transactions with status=pending

    Backend->>PG: Request billing payment
    PG->>PGDB: Check idempotency_key
    PG->>Card: Request card approval by card_token
    Card->>CardDB: INSERT tx
    Card-->>PG: Return approval_no and card_tx_id
    PG->>PGDB: INSERT or UPDATE transactions
    PG-->>Backend: Return pg_tx_id and approval_no

    Backend->>DB: UPDATE transactions with status=success
    Backend->>DB: INSERT payment_notification_outbox status=pending
    Backend->>DB: UPDATE parking_sessions with status=completed
    Backend->>PMS: Notify paid
    Backend-->>App: Return payment complete and parked=false
    Backend->>SQS: Send payment.completed from outbox
    SQS->>Lambda: Trigger payment notification handler
    Lambda->>IoT: Publish payment.completed
    IoT-->>App: Payment completed notification
