# ── CarPayIn DB Exporter 환경변수 ─────────────────────────────────────────────
# SSM 포트 포워딩 + SSH 터널 기반 (로컬에서 실행)
# QUICKSTART.md 의 터널 명령을 먼저 실행한 뒤 이 파일을 .env로 복사하세요.

# CarPayIn Backend DB — AWS RDS (퍼블릭 엔드포인트, 직접 접속)
# RDS 보안 그룹에서 내 IP:5432 허용 필요
CARPAYIN_DB_URL=postgresql://carpayin:carpayin1234@carpayin-postgresql.cne64k2iua9r.ap-northeast-2.rds.amazonaws.com:5432/carpayin_dev?sslmode=require

# Mock PG DB — SSM 터널 → localhost:15433
MOCK_PG_DB_URL=postgresql://mockpg:mockpgdb1234@host.docker.internal:15433/mockpgdb

# PMS DB — SSM 터널 → localhost:15435
PMS_DB_URL=postgresql://mockpms:mockpmsdb1234@host.docker.internal:15435/mockpmsdb

# Mock Card DB — SSH 터널 → localhost:15434 (OpenStack, trust 인증)
MOCK_CARD_DB_URL=postgresql://postgres@host.docker.internal:15434/mock_card_db

# CarPayIn Redis — AWS ElastiCache Serverless (SSM 터널 → localhost:16379)
CARPAYIN_REDIS_URL=redis://host.docker.internal:16379

# ── Exporter 설정 ──────────────────────────────────────────────────────────────
SCRAPE_INTERVAL_SECONDS=5
EXPORTER_PORT=9001

# ── Grafana 관리자 계정 ────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=carpayin123
