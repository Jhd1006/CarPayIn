# Webots AWS 모드 실행 설정
# 이 파일을 .env.aws 로 복사해서 사용하세요 (.env.aws는 gitignore됩니다)
#
# 사용법:
#   cp carpayin-webots/.env.aws.example carpayin-webots/.env.aws
#   ./carpayin-webots/start_carpayin_webots.sh --aws

CARPAYIN_PMS_URL=http://mockpms-public-alb-810192222.ap-northeast-2.elb.amazonaws.com
CARPAYIN_BACKEND_URL=http://hd-public-alb-204074971.ap-northeast-2.elb.amazonaws.com

# 선택: 차량/주차장 설정 (아래 기본값 사용 가능)
# WEBOTS_PLATE=12가3456
# WEBOTS_LOT_ID=LOT_TEST_01
# WEBOTS_DRIVE_MODE=auto
