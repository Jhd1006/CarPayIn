# Copy this file to .env for local Docker Compose.
# Do not commit .env.
#
# AWS deploys should set APP_ENV=aws and provide real endpoint/secret values
# through ECS task environment variables, EC2 systemd env files, or a secret
# manager. Local defaults are intentionally development-only.

APP_ENV=local

# Car Pay-in backend public endpoint.
# Local Android emulator can reach host port 8000 through 10.0.2.2.
PUBLIC_BASE_URL=http://10.0.2.2:8000

# Car Pay-in backend dependencies.
DATABASE_URL=postgresql+psycopg://dev_user:dev_pass@carpayin-postgres:5432/carpayin_dev
REDIS_URL=redis://redis:6379/0
PG_BASE_URL=http://mock-pg:8000
PG_INTERNAL_BASE_URL=http://mock-pg:8000
PG_PUBLIC_BASE_URL=http://10.0.2.2:8002
CARD_WEBHOOK_URL=http://carpayin-backend:8000/card/webhook
PMS_BASE_URL=http://pms:8000
MQTT_ENABLED=true
MQTT_HOST=mqtt
MQTT_PORT=1883
CARPAYIN_MQTT_BROKER_URL=tcp://10.0.2.2:1883

# Payment notification delivery.
# AWS deploys can send outbox events to SQS and let Lambda publish to IoT Core.
AWS_REGION=ap-northeast-2
PAYMENT_NOTIFICATION_QUEUE_URL=
PAYMENT_NOTIFICATION_PUBLISH_ENABLED=false

# Car Pay-in backend secrets.
APP_TOKEN_SECRET=carpayin-dev-token-secret
APP_REFRESH_TOKEN_HASH_SECRET=
HYUNDAI_TOKEN_ENCRYPTION_SECRET=hyundai-dev-token-secret
PG_WEBHOOK_SECRET=mock-pg-webhook-secret
PMS_WEBHOOK_SECRET=pms-webhook-secret

# Hyundai OAuth/API.
HYUNDAI_CLIENT_ID=
HYUNDAI_CLIENT_SECRET=
HYUNDAI_AUTHORIZE_URL=https://prd.kr-ccapi.hyundai.com/api/v1/user/oauth2/authorize
HYUNDAI_TOKEN_URL=https://prd.kr-ccapi.hyundai.com/api/v1/user/oauth2/token
HYUNDAI_USER_INFO_URL=https://prd.kr-ccapi.hyundai.com/api/v1/user/profile
HYUNDAI_VEHICLE_LIST_URL=https://dev.kr-ccapi.hyundai.com/api/v1/car/profile/carlist

# Local E2E has no MOLIT mock service yet. Set true with real MOLIT credentials.
MOLIT_VERIFY_ENABLED=false
MOLIT_BASE_URL=
MOLIT_API_KEY=

# Mock PG.
MOCK_PG_DATABASE_URL=postgresql+psycopg://dev_user:dev_pass@mock-pg-postgres:5432/mock_pg_dev
MOCK_CARD_BASE_URL=http://mock-card:8000
MOCK_PG_ALLOW_FAKE_CARD_ON_VERIFY_FAILURE=true

# PMS.
PMS_DATABASE_URL=postgresql+psycopg://dev_user:dev_pass@pms-postgres:5432/pms_dev
PMS_FEE_PER_30_MINUTES=500
BARRIER_ENABLED=true
BARRIER_ENTRY_URL=http://<webots-barrier-host>:40026/open
BARRIER_EXIT_URL=http://<webots-barrier-host>:40027/open

# Mock Card is managed separately in cloud deploys, but local compose still uses it.
MOCK_CARD_DATABASE_URL=postgresql+psycopg://dev_user:dev_pass@mock-card-postgres:5432/mock_card_dev
MOCK_CARD_SECURITY_SECRET=mock-card-dev-secret

# Local Postgres containers.
CARPAYIN_POSTGRES_DB=carpayin_dev
CARPAYIN_POSTGRES_USER=dev_user
CARPAYIN_POSTGRES_PASSWORD=dev_pass
MOCK_CARD_POSTGRES_DB=mock_card_dev
MOCK_CARD_POSTGRES_USER=dev_user
MOCK_CARD_POSTGRES_PASSWORD=dev_pass
MOCK_PG_POSTGRES_DB=mock_pg_dev
MOCK_PG_POSTGRES_USER=dev_user
MOCK_PG_POSTGRES_PASSWORD=dev_pass
PMS_POSTGRES_DB=pms_dev
PMS_POSTGRES_USER=dev_user
PMS_POSTGRES_PASSWORD=dev_pass
