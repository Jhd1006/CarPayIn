# Copy this file to .env and fill the values before running real OAuth.
# Do not commit .env.

PUBLIC_BASE_URL=

HYUNDAI_CLIENT_ID=
HYUNDAI_CLIENT_SECRET=
HYUNDAI_AUTHORIZE_URL=https://prd.kr-ccapi.hyundai.com/api/v1/user/oauth2/authorize
HYUNDAI_TOKEN_URL=https://prd.kr-ccapi.hyundai.com/api/v1/user/oauth2/token
HYUNDAI_USER_INFO_URL=https://prd.kr-ccapi.hyundai.com/api/v1/user/profile
HYUNDAI_VEHICLE_LIST_URL=https://dev.kr-ccapi.hyundai.com/api/v1/car/profile/carlist

# Android emulator can reach host port 8002 through 10.0.2.2.
# Use an AWS/ngrok HTTPS URL for a physical device or cloud deploy.
PG_PUBLIC_BASE_URL=http://10.0.2.2:8002

# Local E2E has no MOLIT mock service yet. Set true with real MOLIT credentials.
MOLIT_VERIFY_ENABLED=false
MOLIT_BASE_URL=
MOLIT_API_KEY=

# Local demo mode lets the Mock PG issue a billing key even for fake card input.
MOCK_PG_ALLOW_FAKE_CARD_ON_VERIFY_FAILURE=true
